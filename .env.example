# BotFather'dan olingan YANGI tokenni kiriting.
BOT_TOKEN=1234567890:REPLACE_WITH_NEW_BOT_TOKEN

# Telegram user IDlar, vergul bilan. IDni @userinfobot orqali bilish mumkin.
ADMIN_IDS=123456789

DATABASE_PATH=./data/bot.sqlite3
TEMP_DIR=./tmp

# Aylana video narxi va yangi foydalanuvchi boshlang'ich balansi (so'm).
CIRCLE_PRICE=5000
INITIAL_BALANCE=0

# Cloud Bot API uchun 49. Local Bot API uchun 1990 ga o'zgartiring.
MAX_DOWNLOAD_MB=49
MAX_DURATION_MINUTES=660

# 2 GB rejimi faqat docker-compose.local.yml bilan ishlaydi.
BOT_API_BASE=
BOT_API_LOCAL=false

# YouTube/Instagram login talab qilsa Netscape formatidagi cookies fayli.
YTDLP_COOKIES_FILE=

# Telegram post havolalarini yuklash uchun https://my.telegram.org ma'lumotlari.
# Bo'sh qoldirilsa foydalanuvchi botga yuborgan/forward qilgan Telegram media ishlaydi.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=./data/telegram_bot

# Format: Telegram Stars:balans,Telegram Stars:balans
STAR_PACKAGES=5:5000,10:10000,15:15000,25:25000,50:55000,100:120000,250:325000,500:700000,1000:1500000

# Foydalanuvchi o'zi miqdor kiritsa: kamida 5 Stars, 1 Star = 1000 so'm.
CUSTOM_STAR_MIN=5
STAR_CREDIT_RATE=1000

# Telegram WebApp. Railway'da bo'sh qoldirilsa RAILWAY_PUBLIC_DOMAIN avtomatik olinadi.
# Boshqa serverda Telegram ichida ochilishi uchun HTTPS public URL kiriting.
WEBAPP_PUBLIC_URL=
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
PHONE_CODE_TTL_SECONDS=300

# Public URL bo'lmasa cloudflared vaqtinchalik HTTPS tunnelini avtomatik yaratadi.
AUTO_TUNNEL=true
