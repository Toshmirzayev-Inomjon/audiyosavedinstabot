# BotFather'dan olingan YANGI tokenni kiriting.
BOT_TOKEN=1234567890:REPLACE_WITH_NEW_BOT_TOKEN

# Telegram user IDlar, vergul bilan. IDni @userinfobot orqali bilish mumkin.
ADMIN_IDS=123456789

DATABASE_PATH=./data/bot.sqlite3
# Railway PostgreSQL plugin bergan URL. Berilsa SQLite o'rniga PostgreSQL ishlaydi.
DATABASE_URL=
TEMP_DIR=./tmp

# Aylana video narxi va yangi foydalanuvchi boshlang'ich balansi (so'm).
CIRCLE_PRICE=5000
INITIAL_BALANCE=0

# Server YouTube/Instagram'dan qayta ishlashi mumkin bo'lgan maksimal hajm.
# Telegramga 49 MB gacha yuboriladi, kattasiga vaqtinchalik link beriladi.
MAX_DOWNLOAD_MB=500
TELEGRAM_UPLOAD_MB=49
MAX_DURATION_MINUTES=660
QUEUE_CONCURRENCY=2
DAILY_FREE_LIMIT=3
PREMIUM_STARS=100
TARIFF_STANDARD_PRICE=25000
TARIFF_PREMIUM_PRICE=50000
TARIFF_STANDARD_STARS=25
TARIFF_PREMIUM_STARS=50
TARIFF_STANDARD_DAILY_LIMIT=15
TARIFF_PERIOD_DAYS=30
REFERRAL_REWARD=5000
REFERRAL_NEW_USER_REWARD=2000
PUBLIC_FILE_TTL_SECONDS=3600

# local: API kalitisiz ichki AI. gemini/openai faqat ixtiyoriy tashqi provider.
AI_PROVIDER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-1.5
STANDARD_AI_DAILY_LIMIT=20
PREMIUM_AI_DAILY_LIMIT=100

# 2 GB rejimi faqat docker-compose.local.yml bilan ishlaydi.
BOT_API_BASE=
BOT_API_LOCAL=false

# YouTube/Instagram login talab qilsa Netscape formatidagi cookies fayli.
YTDLP_COOKIES_FILE=

# Telegram post havolalarini yuklash uchun https://my.telegram.org ma'lumotlari.
# Bo'sh qoldirilsa foydalanuvchi botga yuborgan/forward qilgan Telegram media ishlaydi.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=./data/telegram_bot

# Format: Telegram Stars:balans,Telegram Stars:balans
STAR_PACKAGES=5:5000,10:10000,15:15000,25:25000,50:55000,100:120000,250:325000,500:700000,1000:1500000

# Foydalanuvchi o'zi miqdor kiritsa: kamida 5 Stars, 1 Star = 1000 so'm.
CUSTOM_STAR_MIN=5
STAR_CREDIT_RATE=1000

# Telegram WebApp. Railway'da bo'sh qoldirilsa RAILWAY_PUBLIC_DOMAIN avtomatik olinadi.
# Boshqa serverda Telegram ichida ochilishi uchun HTTPS public URL kiriting.
WEBAPP_PUBLIC_URL=
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
PHONE_CODE_TTL_SECONDS=300

# High-traffic Super App stack (`python -m bot.main` + Celery worker).
# `docker-compose.superapp.yml` ishlatilsa DATABASE_URL/REDIS_URL avtomatik
# container ichidagi PostgreSQL va Redisga ulanadi.
REDIS_URL=redis://redis:6379/0
SENTRY_DSN=
WEBHOOK_URL=
WEBHOOK_SECRET=
BOT_HOST=0.0.0.0
BOT_PORT=8080
STORAGE_DIR=./tmp/superapp
MAX_DURATION_SECONDS=14400
CONCURRENT_DOWNLOADS=4
WORKER_CONCURRENCY=2
ROTATING_PROXIES=
ROTATING_PROXY_FILE=
AUDD_API_KEY=
LOCAL_AI_ENABLED=true
PROGRESS_INTERVAL_SECONDS=3
CACHE_TTL_DAYS=90
